modules = ["nodejs-20", "php-8.2", "web"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-25_05"
packages = ["jq"]

[deployment]
deploymentTarget = "autoscale"
build = ["cd", "client", "&&", "npm", "run", "build"]
run = ["cd", "client", "&&", "npx", "vite", "preview", "--host", "0.0.0.0", "--port", "5000"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 43031
externalPort = 3000

[env]
PORT = "5000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[agent]
expertMode = true
