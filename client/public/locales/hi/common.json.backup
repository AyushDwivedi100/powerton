    "responses": {
      "productSelection": "बहुत अच्छा! मैं आपकी आवश्यकताओं के लिए सही उत्पाद खोजने में आपकी मदद करूंगा। आप किस श्रेणी में रुचि रखते हैं?",
      "serviceSelection": "उत्कृष्ट विकल्प! हमारी व्यापक सेवाएं सुनिश्चित करती हैं कि आपकी परियोजनाएं शुरू से अंत तक सफल हों। आपको किस सेवा की आवश्यकता है?",
      "troubleshootingMain": "मैं किसी भी तकनीकी समस्या को हल करने में आपकी मदद करने के लिए यहाँ हूँ! हमारी विशेषज्ञ टीम के पास सामान्य औद्योगिक स्वचालन समस्याओं के समाधान हैं। आप किस प्रकार की समस्या का सामना कर रहे हैं?",
      "companyInfo": "पावरटन इंजीनियरिंग प्राइवेट लिमिटेड 2008 से औद्योगिक स्वचालन में एक विश्वसनीय नेता रहा है। हमने अत्याधुनिक समाधानों के साथ भारत भर में 1200+ परियोजनाएं पूरी की हैं।",
      "sensorsCategory": "बेहतरीन पसंद! हमारे सेंसर और मापन उपकरण आपकी औद्योगिक प्रक्रियाओं के लिए सटीक, विश्वसनीय डेटा प्रदान करते हैं। तापमान से प्रवाह मापन तक, हमारे पास सब कुछ है!",
      "electricalCategory": "उत्कृष्ट! हमारे इलेक्ट्रिकल घटक सुरक्षित और विश्वसनीय विद्युत वितरण सुनिश्चित करते हैं। सर्किट ब्रेकर से पावर सप्लाई तक, हमारे पास आपके इलेक्ट्रिकल इन्फ्रास्ट्रक्चर के लिए सब कुछ है।",
      "automationCategory": "स्मार्ट विकल्प! हमारे स्वचालन सिस्टम में पीएलसी, स्काडा, डीसीएस और एचएमआई समाधान शामिल हैं जो आपकी औद्योगिक प्रक्रियाओं को अनुकूलित करते हैं और उत्पादकता बढ़ाते हैं।",
      "solarCategory": "शानदार! सोलर ऊर्जा भविष्य है! हम पैनल से इन्वर्टर, बैटरी और मॉनिटरिंग सिस्टम तक पूर्ण सोलर समाधान प्रदान करते हैं। स्थायी और लागत-प्रभावी ऊर्जा उत्पादन के लिए बिल्कुल सही।",
      "safetyCategory": "सुरक्षा पहले! यह हमारा मूलमंत्र है। हमारे सुरक्षा और सुरक्षात्मक उपकरण औद्योगिक वातावरण में कर्मचारी सुरक्षा और उपकरण सुरक्षा सुनिश्चित करते हैं।",
      "installationService": "हमारी स्थापना और कमीशनिंग सेवा सुनिश्चित करती है कि आपका उपकरण पहले दिन से ही बिल्कुल सही तरीके से स्थापित हो। हम साइट तैयारी से अंतिम परीक्षण और सत्यापन तक सब कुछ संभालते हैं, पूर्ण अनुपालन प्रमाणन के साथ।",
      "electricalTroubleshooting": "इलेक्ट्रिकल समस्याएं जटिल हो सकती हैं! सामान्य समस्याओं में विद्युत उतार-चढ़ाव, सर्किट ओवरलोड, ग्राउंडिंग समस्याएं और कंपोनेंट विफलताएं शामिल हैं। हमारे समाधान औद्योगिक इलेक्ट्रिकल सुरक्षा के लिए IEC 60204 और IS 732 मानकों के अनुपालन में हैं। आप किस विशिष्ट इलेक्ट्रिकल समस्या का सामना कर रहे हैं?"
    }
